        <dc:Bounds x="490" y="311" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Exact" bpmnElement="Task_Exact">
        <dc:Bounds x="690" y="311" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_AI_Request" bpmnElement="Task_AI_Request">
        <dc:Bounds x="870" y="311" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_AI_Wait" bpmnElement="Task_AI_Wait">
        <dc:Bounds x="1050" y="311" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Reject" bpmnElement="Task_Reject">
        <dc:Bounds x="350" y="200" width="150" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Rejected" bpmnElement="End_Rejected">
        <dc:Bounds x="557" y="212" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="535" y="188" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Review" bpmnElement="Gateway_Review" isMarkerVisible="true">
        <dc:Bounds x="1425" y="326" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1405" y="376" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Merge" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="1870" y="326" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1861" y="376" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Matching" bpmnElement="End_Matching">
        <dc:Bounds x="2492" y="377" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2482" y="413" width="56" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_WaitPOS" bpmnElement="Task_WaitPOS">
        <dc:Bounds x="2255" y="360" width="130" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Publish" bpmnElement="Task_Publish">
        <dc:Bounds x="2005" y="362" width="130" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Export" bpmnElement="Task_Export">
        <dc:Bounds x="1950" y="207" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_WaitSAP" bpmnElement="Task_WaitSAP">
        <dc:Bounds x="2110" y="207" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Report" bpmnElement="Task_Report">
        <dc:Bounds x="2260" y="207" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_M_1" bpmnElement="Flow_M_1">
        <di:waypoint x="186" y="310" />
        <di:waypoint x="203" y="310" />
        <di:waypoint x="203" y="351" />
        <di:waypoint x="220" y="351" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_M_2" bpmnElement="Flow_M_2">
        <di:waypoint x="370" y="351" />
        <di:waypoint x="400" y="351" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_M_Invalid" bpmnElement="Flow_M_Invalid">
        <di:waypoint x="425" y="326" />
        <di:waypoint x="425" y="260" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="400" y="293" width="17" height="14" />
